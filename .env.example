# Server
PORT=3000
ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=secret
DB_NAME=Play5
DB_SSL_MODE=disable

# JWT
JWT_SECRET=your-super-secret-key-min-32-chars
JWT_EXPIRATION_HOURS=24

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=

# Optional: WhatsApp notifications
WHATSAPP_ENABLED=false
